<!-- ══════════ JS ══════════ -->
<script>
  /* ── Smooth scroll ── */
  function scrollToEl(id) {
    var el = document.getElementById(id);
    if (el) el.scrollIntoView({ behavior: 'smooth' });
  }

  /* ── FAQ ── */
  var FAQS = [
    {
      q: 'ما الفرق بينكم وبين وكالة تسويق عادية؟',
      a: 'الوكالة العادية بتجيبلك كليكات — وإنت اللي لازم تتابع وتحول. إحنا بنشتغل بشكل مختلف: بنطلق الإعلانات، ونتابع كل استفسار، ونحوّله لموعد مؤكد في جدولك. إنت بتستقبل مريض جاهز، مش ليد بارد.'
    },
    {
      q: 'كيف يعمل ضمان 90 يوم؟',
      a: 'لو ما حققناش الهدف المتفق عليه خلال 90 يوم — نستمر في العمل لصالحك بدون أي تكلفة إضافية حتى نوصل للهدف. مش بنفر ومش بنتعذر.'
    },
    {
      q: 'كم يستغرق حتى أرى نتائج؟',
      a: 'في الغالب بتشوف أول مواعيد خلال 7-14 يوم من إطلاق الحملة. النتائج القوية بتظهر بشكل واضح من الأسبوع الثالث.'
    },
    {
      q: 'هل أحتاج ميزانية إعلانات كبيرة؟',
      a: 'لا. بنقدر نبدأ بميزانية معقولة ونزيدها حسب النتائج. ميزانية الإعلانات منفصلة عن خدمتنا — إنت بتتحكم فيها بنفسك.'
    },
    {
      q: 'ما هي تخصصات الأسنان اللي تشتغلون عليها؟',
      a: 'نتخصص في الخدمات ذات القيمة الأعلى: زراعة الأسنان، الفينير، التقويم الشفاف (إنفيزاليين)، والابتسامة الهوليوودية. هذه الخدمات تعطي أفضل عائد على الإعلان.'
    }
  ];

  var fl = document.getElementById('faq-list');
  if(fl) {
    FAQS.forEach(function(f, i) {
      var d = document.createElement('div');
      d.className = 'faq-item';
      d.innerHTML =
        '<div class="faq-q" onclick="toggleFaq(' + i + ')">' +
          f.q +
          '<span class="faq-arr" id="fa' + i + '">▾</span>' +
        '</div>' +
        '<div class="faq-body" id="fb' + i + '">' +
          '<div class="faq-body-inner">' + f.a + '</div>' +
        '</div>';
      fl.appendChild(d);
    });
  }

  function toggleFaq(i) {
    var body = document.getElementById('fb' + i);
    var item = body.parentElement;
    var isOpen = item.classList.contains('open');
    document.querySelectorAll('.faq-item').forEach(function(el) {
      el.classList.remove('open');
      el.querySelector('.faq-body').style.maxHeight = '0';
    });
    if (!isOpen) {
      item.classList.add('open');
      body.style.maxHeight = body.scrollHeight + 'px';
    }
  }

  /* ── Form submit ── */
  function doSubmit() {
    var name  = document.getElementById('f-name').value.trim();
    var phone = document.getElementById('f-phone').value.trim();
    var city  = document.getElementById('f-city').value.trim();
    
    if (!name || !phone) {
      alert('من فضلك أدخل الاسم ورقم الجوال');
      return;
    }
    
    document.getElementById('sbox').style.display = 'block';
    var btn = document.getElementById('sub-btn');
    btn.disabled = true;
    btn.textContent = 'تم الإرسال ✓';

    /* ══ للتكامل مع Systeme.io أو أي CRM، يتم وضع كود الـ Fetch هنا ══ */
    console.log("Form Submitted:", { name, phone, city });
  }
</script>
</body>
